# FinSight FastAPI Backend — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env

# ── Required ──────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── App ───────────────────────────────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
APP_VERSION=0.1.0

# ── CORS (comma-separated list of allowed frontend origins) ───
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://your-app.vercel.app

# ── Claude ────────────────────────────────────────────────────
CLAUDE_MODEL=claude-sonnet-4-6
MAX_TOKENS=2048

# ── RAG ───────────────────────────────────────────────────────
FAISS_INDEX_PATH=/tmp/finsight_faiss
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_RESULTS=5

# ── yfinance ─────────────────────────────────────────────────
YFINANCE_CACHE_TTL=600
YFINANCE_MAX_RETRIES=3
YFINANCE_TIMEOUT=15.0
