# ============================================================
# FinSight — Environment Variables
# Copy to .env and fill in your values. NEVER commit .env
# ============================================================

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# App
APP_ENV=development          # development | production
LOG_LEVEL=INFO

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K_RESULTS=5

# Cache
CACHE_TTL_SECONDS=300        # yfinance data cache duration
